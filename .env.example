# Copy to .env.local and fill in. Never commit .env.local.

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
SANITY_API_TOKEN=
# Shared secret for the Sanity -> /api/revalidate webhook (any long random string)
SANITY_REVALIDATE_SECRET=

# Resend
RESEND_API_KEY=
CONTACT_TO_EMAIL=garrett.loughman@adlbusinessconsulting.com
CONTACT_FROM_EMAIL=info@adlbusinessconsulting.com

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Places (dynamic reviews) — optional; falls back to static review if blank
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Site
NEXT_PUBLIC_SITE_URL=https://www.adlbusinessconsulting.com
